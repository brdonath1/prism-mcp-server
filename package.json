{
  "name": "prism-mcp-server",
  "version": "4.7.0",
  "description": "PRISM MCP Server — remote MCP server for GitHub-backed session continuity",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch & node --watch dist/index.js",
    "lint": "biome check --formatter-enabled=false src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "prism",
    "github"
  ],
  "author": "Brian (brdonath1)",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.101",
    "@anthropic-ai/claude-code": "latest",
    "@anthropic-ai/sdk": "^0.81.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "express": "^5.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
