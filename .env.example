GITHUB_PAT=ghp_your_personal_access_token_here
GITHUB_OWNER=brdonath1
FRAMEWORK_REPO=prism-framework
PORT=3000
LOG_LEVEL=info

# IP Allowlisting (enabled by default)
# Anthropic's 160.79.104.0/21 is always allowed when IP allowlisting is active.
# Add additional CIDR ranges (comma-separated) for personal/VPN access:
# ALLOWED_CIDRS=203.0.113.0/24,198.51.100.42/32
# To disable IP allowlisting entirely (e.g., local development):
# ENABLE_IP_ALLOWLIST=false

# Optional Bearer token auth (secondary to IP allowlist)
# MCP_AUTH_TOKEN=your-secret-token-here

# Railway operations gateway (brief-103). When set, unlocks railway_logs,
# railway_deploy, railway_env, and railway_status tools. Workspace-scoped token.
# RAILWAY_API_TOKEN=your-railway-workspace-token

# Claude Code OAuth token (sk-ant-oat01-*) for cc_dispatch.
# Generate via `claude setup-token` on a Mac signed into the intended
# Claude Max subscription. Required to enable cc_dispatch + cc_status —
# when unset, those tools are not registered. Also selects the cc_subprocess
# synthesis transport when SYNTHESIS_*_TRANSPORT opts in.
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Anthropic API key — enables intelligence-brief / PDU / draft synthesis via the
# Messages API transport. When unset, synthesis is disabled unless a call site
# is routed to the cc_subprocess transport (which uses CLAUDE_CODE_OAUTH_TOKEN).
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Synthesis routing (production knobs — see docs/model-bump.md). The model is
# the registry default (SYNTHESIS_MODEL_ID in src/models.ts) unless overridden
# here per call site (brief / draft / pdu). Transport: messages_api | cc_subprocess.
# SYNTHESIS_BRIEF_MODEL=
# SYNTHESIS_DRAFT_MODEL=
# SYNTHESIS_PDU_MODEL=
# SYNTHESIS_BRIEF_TRANSPORT=messages_api
# SYNTHESIS_DRAFT_TRANSPORT=messages_api
# SYNTHESIS_PDU_TRANSPORT=messages_api

# Claude Code dispatch model override (default: CC_DISPATCH_MODEL_ID in src/models.ts)
# CC_DISPATCH_MODEL=
# CC_DISPATCH_MAX_TURNS=50

# NOTE: src/config.ts is the authoritative inventory of all ~40 env vars
# (timeouts, oversize/byte caps, etc.). This file lists the common ones.
